# PostgreSQL
POSTGRES_USER=spmis
POSTGRES_PASSWORD=spmis_secret
POSTGRES_DB=spmis_db
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_DSN=postgres://spmis:spmis_secret@localhost:5432/spmis_db?sslmode=disable

# MongoDB
MONGO_USER=spmis
MONGO_PASSWORD=spmis_secret
MONGO_DB=spmis_db
MONGO_PORT=27017
MONGO_HOST=localhost
MONGO_URI=mongodb://spmis:spmis_secret@localhost:27017/spmis_db?authSource=admin

# Redis
REDIS_PASSWORD=spmis_secret
REDIS_PORT=6380
REDIS_HOST=localhost
REDIS_ADDR=localhost:6380

# Application
APP_PORT=8080
APP_ENV=development
FRONTEND_PORT=3000
JWT_SECRET=change-me-in-production
LOG_LEVEL=debug
